{
  "name": "naedon-agent",
  "version": "0.4.0",
  "description": "뇽죵이 에이전트 — AI-native autonomous agent server with MCP protocol, Obsidian memory, multi-model support, and dynamic persona system",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "naedon-agent": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "data/personas/**/*.md",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dashboard": "tsx src/dashboard-main.ts",
    "test:mcp": "tsx scripts/test-mcp.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "autonomous-agent",
    "obsidian",
    "persona",
    "ollama",
    "llm",
    "grounding",
    "fact-check"
  ],
  "author": "뇽죵이Agent Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nongjong/naedon-agent.git"
  },
  "homepage": "https://github.com/nongjong/naedon-agent#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}


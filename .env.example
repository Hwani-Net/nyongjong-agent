# === 뇽죵이 에이전트 환경변수 ===

# Obsidian Vault 절대 경로
OBSIDIAN_VAULT_PATH=C:/Users/AIcreator/ObsidianVault

# Obsidian 내 에이전트 데이터 폴더 (Vault 내 상대 경로)
AGENT_DATA_DIR=뇽죵이Agent

# Ollama 서버 URL (로컬 LLM)
OLLAMA_URL=http://localhost:11434

# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL=info

# MCP 서버 전송 방식 (stdio | sse)
MCP_TRANSPORT=stdio

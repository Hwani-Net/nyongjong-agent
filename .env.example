# === 뇽죵이 에이전트 v0.4.0 환경변수 ===

# ─── Required ───────────────────────────────────────
# Obsidian Vault 절대 경로
OBSIDIAN_VAULT_PATH=E:/Agent/뇽죵이Agent/data

# Obsidian 내 에이전트 데이터 폴더 (상대 경로)
AGENT_DATA_DIR=.

# ─── Ollama (페르소나 시뮬레이션용) ──────────────────
OLLAMA_URL=http://localhost:11434

# ─── 로깅 ──────────────────────────────────────────
# 옵션: debug | info | warn | error
LOG_LEVEL=info

# ─── MCP 서버 ──────────────────────────────────────
MCP_TRANSPORT=stdio

# ─── Dashboard ─────────────────────────────────────
DASHBOARD_PORT=3100

# ─── Grounding API Keys (선택) ─────────────────────
# 통계청 KOSIS: https://kosis.kr/openapi/
KOSIS_API_KEY=

# 네이버: https://developers.naver.com/
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

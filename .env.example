# === 뇽죵이 에이전트 v0.4.0 환경변수 ===

# ─── Required ───────────────────────────────────────
# Obsidian Vault 절대 경로
OBSIDIAN_VAULT_PATH=E:/Agent/뇽죵이Agent/data

# Obsidian 내 에이전트 데이터 폴더 (상대 경로)
AGENT_DATA_DIR=.

# ─── Ollama (페르소나 시뮬레이션용) ──────────────────
OLLAMA_URL=http://localhost:11434

# ─── 로깅 ──────────────────────────────────────────
# 옵션: debug | info | warn | error
LOG_LEVEL=info

# ─── MCP 서버 ──────────────────────────────────────
MCP_TRANSPORT=stdio

# ─── Dashboard ─────────────────────────────────────
DASHBOARD_PORT=3100

# ─── Grounding API Keys (선택) ─────────────────────
# 통계청 KOSIS: https://kosis.kr/openapi/
KOSIS_API_KEY=

# 네이버: https://developers.naver.com/
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─── API Key 불필요 어댑터 ─────────────────────────────
# 아래 어댑터들은 키 없이 동작합니다. 설정 불필요.
# law-kr     → 국가법령정보센터 공개 API (law.go.kr/DRF)
# app-reviews → Google Play Store HTML 스크래핑
# google-trends → RSS 피드 스크래핑
# web-scraper → 일반 웹 크롤링
